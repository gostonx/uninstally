    "Your Mac is tidy — no orphaned files from uninstalled apps were detected.": {
      "comment": "A description of the state when no leftovers are found.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Mac ist aufgeräumt — es wurden keine verwaisten Dateien von deinstallierten Apps erkannt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your Mac is tidy — no orphaned files from uninstalled apps were detected."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu Mac está limpio — no se detectaron archivos huérfanos de apps desinstaladas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre Mac est propre — aucun fichier orphelin d'apps désinstallées n'a été détecté."
          }
        },
        "it": {

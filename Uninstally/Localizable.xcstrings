    "Collections only organize apps — they never change what's installed.": {
      "comment": "A description of how Collections work.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sammlungen organisieren nur Apps — sie ändern nie, was installiert ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Collections only organize apps — they never change what's installed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las Colecciones solo organizan apps — nunca cambian lo instalado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les Collections organisent seulement les apps — elles ne changent rien à ce qui est installé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Collezioni organizzano solo le app — non cambiano ciò che è installato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コレクションはアプリを整理するだけで、インストール済みの内容は変更しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",

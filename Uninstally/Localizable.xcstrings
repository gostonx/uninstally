    "Applications and related files will be moved to the Trash. You can restore them until the Trash is emptied.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apps und zugehörige Dateien werden in den Papierkorb verschoben. Sie können sie wiederherstellen, bis der Papierkorb geleert wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Applications and related files will be moved to the Trash. You can restore them until the Trash is emptied."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las apps y archivos relacionados se moverán a la Papelera. Puedes restaurarlos hasta vaciarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les apps et fichiers associés seront mis à la Corbeille. Vous pouvez les restaurer jusqu'au vidage."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "App e file correlati saranno spostati nel Cestino. Puoi ripristinarli finché il Cestino non viene svuotato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリと関連ファイルはゴミ箱に移動されます。ゴミ箱を空にするまで復元できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱과 관련 파일이 휴지통으로 이동됩니다. 휴지통을 비우기 전까지 복원할 수 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Apps e arquivos relacionados serão movidos para a Lixeira. Você pode restaurá-los até esvaziá-la."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用和相关文件将移至废纸篓。清空废纸篓之前可以恢复。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "應用程式和相關檔案將移至垃圾桶。清空垃圾桶之前可以恢復。"
          }
        }
      }
    },
    "Applications and related files will be permanently deleted. This action cannot be undone.": {

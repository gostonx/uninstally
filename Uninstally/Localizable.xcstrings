    "Uninstally matches files by bundle identifier — not just by name — across every Library location, so nothing gets missed and nothing unrelated gets touched.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Uninstally gleicht Dateien anhand der Bundle-ID ab — nicht nur nach Namen — an jedem Bibliotheksort, sodass nichts übersehen und nichts Unbeteiligtes berührt wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uninstally matches files by bundle identifier — not just by name — across every Library location, so nothing gets missed and nothing unrelated gets touched."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Uninstally empareja archivos por identificador de bundle — no solo por nombre — en cada ubicación de la Biblioteca, para que nada se pierda y nada no relacionado se toque."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uninstally fait correspondre les fichiers par identifiant de bundle — pas seulement par nom — dans chaque emplacement Bibliothèque, pour ne rien manquer et ne rien toucher d'inutile."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Uninstally abbina i file per identificatore bundle — non solo per nome — in ogni posizione Libreria, così nulla viene tralasciato e nulla di estraneo viene toccato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Uninstallyはバンドル識別子でファイルを照合します — 名前だけでなく — すべてのライブラリの場所で、見落としがなく、無関係なものには触れません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Uninstally는 번들 식별자로 파일을 일치시킵니다 — 이름만이 아니라 — 모든 라이브러리 위치에서, 놓치는 것이 없고 관련 없는 것은 건드리지 않습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Uninstally combina arquivos por identificador de bundle — não apenas por nome — em cada local da Biblioteca, para que nada seja perdido e nada não relacionado seja tocado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Uninstally 通过 Bundle 标识符匹配文件 — 而不仅仅是名称 — 在每个资源库位置，确保不遗漏任何内容，也不触及无关内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Uninstally 透過 Bundle 識別碼比對檔案 — 而不僅僅是名稱 — 在每個資源庫位置，確保不遺漏任何內容，也不觸及無關內容。"
          }
        }
      }
    },

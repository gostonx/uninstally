    "You review everything before it's removed. Files go to the Trash where possible, and admin actions ask for permission only when needed.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie überprüfen alles vor dem Entfernen. Dateien werden wenn möglich in den Papierkorb verschoben, und Admin-Aktionen fragen nur bei Bedarf nach Erlaubnis."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You review everything before it's removed. Files go to the Trash where possible, and admin actions ask for permission only when needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisas todo antes de eliminarlo. Los archivos van a la Papelera cuando es posible, y las acciones de administrador piden permiso solo cuando es necesario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous vérifiez tout avant suppression. Les fichiers vont à la Corbeille quand c'est possible, et les actions admin ne demandent l'autorisation que si nécessaire."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esamini tutto prima della rimozione. I file vanno nel Cestino quando possibile, e le azioni admin richiedono il permesso solo quando necessario."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除前にすべてを確認します。可能な場合はファイルをゴミ箱に移動し、管理者権限が必要な場合のみ許可を求めます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "제거하기 전에 모든 것을 검토합니다. 가능하면 파일을 휴지통으로 보내고, 관리자 작업은 필요할 때만 권한을 요청합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você revisa tudo antes de remover. Os arquivos vão para a Lixeira quando possível, e as ações de administrador pedem permissão apenas quando necessário."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除前您会检查所有内容。文件尽可能放入废纸篓，管理员操作仅在必要时请求权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除前您會檢查所有內容。檔案盡可能放入垃圾桶，管理員操作僅在必要時請求權限。"
          }
        }
      }
    },

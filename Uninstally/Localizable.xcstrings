    "This permanently removes every entry from the history. It does not affect files already in the Trash.": {
      "comment": "A message displayed in a confirmation dialog.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernt jeden Eintrag dauerhaft aus dem Verlauf. Bereits im Papierkorb befindliche Dateien sind nicht betroffen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This permanently removes every entry from the history. It does not affect files already in the Trash."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina permanentemente cada entrada del historial. No afecta a los archivos ya en la Papelera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprime définitivement chaque entrée de l'historique. N'affecte pas les fichiers déjà dans la Corbeille."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuove definitivamente ogni voce dalla cronologia. Non influisce sui file già nel Cestino."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "履歴からすべてのエントリを完全に削除します。既にゴミ箱にあるファイルには影響しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기록에서 모든 항목을 영구적으로 삭제합니다. 이미 휴지통에 있는 파일에는 영향을 주지 않습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove permanentemente todas as entradas do histórico. Não afeta arquivos já na Lixeira."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从历史中永久删除所有条目。不影响已在废纸篓中的文件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從歷史中永久刪除所有條目。不影響已在垃圾桶中的檔案。"
          }
        }
      }
    },
